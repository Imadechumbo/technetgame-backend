PORT=3000
NODE_ENV=production
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ALLOWED_ORIGINS=https://technetgame.com.br,https://www.technetgame.com.br,https://technetgame-site.pages.dev
CORS_ORIGIN=https://technetgame.com.br,https://www.technetgame.com.br,https://technetgame-site.pages.dev
OPENCLAW_ENABLED=true
DEFAULT_PROVIDER=openai-compatible
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_CHAT_MODEL=gpt-4o-mini
DEFAULT_CODE_MODEL=deepseek-chat
FORCE_PRO_FOR_ALL_TEST_USERS=true
REFRESH_TOKEN=
ALLOW_LOCAL_REFRESH_WITHOUT_TOKEN=true

# TechNet AI providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
